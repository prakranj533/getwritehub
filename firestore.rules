rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(authorId) {
      return isAuthenticated() && (request.auth.uid == authorId || request.auth.token.email == authorId);
    }

    match /books/{bookId} {
      allow read: if resource.data.isPublic == true || 
                    isOwner(resource.data.authorId) ||
                    exists(/databases/$(database)/documents/collaborators/$(request.auth.token.email + '_' + bookId)) ||
                    exists(/databases/$(database)/documents/collaborators/$(request.auth.uid + '_' + bookId));
      
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.authorId);
    }
    
    match /chapters/{chapterId} {
      allow read: if get(/databases/$(database)/documents/books/$(resource.data.bookId)).data.isPublic == true ||
                    isOwner(get(/databases/$(database)/documents/books/$(resource.data.bookId)).data.authorId);
      
      allow create, update, delete: if isOwner(get(/databases/$(database)/documents/books/$(resource.data.bookId)).data.authorId);
    }
    
    match /chapterVersions/{versionId} {
      allow read, write: if isOwner(get(/databases/$(database)/documents/chapters/$(request.resource.data.chapterId)).data.authorId);
    }
    
    match /collaborators/{collaboratorId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(get(/databases/$(database)/documents/books/$(request.resource.data.bookId)).data.authorId);
    }
    
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if request.auth.uid == resource.data.reviewerId || request.auth.token.email == resource.data.reviewerEmail;
    }
  }
}
